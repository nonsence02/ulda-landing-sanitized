{
  "name": "ulda-landing-public",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib *.ts *.mjs --max-warnings=0",
    "lint:fix": "eslint app components lib *.ts *.mjs --fix --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "docs:build": "typedoc",
    "docs:check": "npm run docs:build",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.454.0",
    "next": "15.2.4",
    "next-themes": "^0.4.4",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typedoc": "^0.28.18",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "description": "Sanitized public mirror of the ULDA landing page for academic repository audit."
}
